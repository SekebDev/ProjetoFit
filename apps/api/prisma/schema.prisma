generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  profile      Profile?
  plans        WorkoutPlan[]
  sessions     WorkoutSession[]
  metrics      BodyMetric[]
  game         GameProfile?
  achievements UserAchievement[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthYear   Int?
  heightCm    Float?
  weightKg    Float?
  goal        String // FAT_LOSS | HYPERTROPHY | STRENGTH | GENERAL
  experience  String // BEGINNER | RETURNING | INTERMEDIATE | ADVANCED
  daysPerWeek Int
  sessionMin  Int?
  focusAreas  String[] // Postgres nativo: ["UPPER","SHOULDERS"]
  equipment   String[] // ["BARBELL","DUMBBELL","MACHINE","CABLE"]
  injuries    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  muscleGroup    String // CHEST | BACK | SHOULDERS | ARMS | LEGS | CORE
  category       String // COMPOUND | ISOLATION
  equipment      String // BARBELL | DUMBBELL | MACHINE | CABLE | BODYWEIGHT
  imageUrl       String?
  videoUrl       String?
  instructions   String?
  defaultRestSec Int            @default(60)
  createdAt      DateTime       @default(now())
  planItems      PlanExercise[]
  setLogs        SetLog[]

  @@index([muscleGroup])
  @@index([equipment])
}

model WorkoutPlan {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  source    String    @default("MANUAL") // MANUAL | AI
  notes     String?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  days      PlanDay[]

  // "planos do usuario X, ativo primeiro" e a consulta mais comum.
  @@index([userId])
  @@index([userId, isActive])
}

model PlanDay {
  id        String           @id @default(cuid())
  planId    String
  plan      WorkoutPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  name      String // "Push", "Pull"
  focus     String?
  order     Int
  // Dia da semana agendado (ISO 1=segunda .. 7=domingo), ou null = sem dia fixo.
  // O painel usa isto pra sugerir o "proximo treino"; nullable de proposito,
  // porque nem todo plano se prende a um calendario.
  weekday   Int?
  exercises PlanExercise[]
  sessions  WorkoutSession[]

  @@index([planId])
}

model PlanExercise {
  id         String   @id @default(cuid())
  planDayId  String
  planDay    PlanDay  @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  exerciseId String
  // Restrict (padrao): impede apagar um exercicio que esta em uso num plano.
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  sets       Int
  repScheme  String // "8-12"
  restSec    Int
  notes      String?

  @@index([planDayId])
  @@index([exerciseId])
}

model WorkoutSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planDayId String?
  // SetNull, nao Restrict: editar um plano apaga e recria os PlanDay
  // (plans.service.update). Com Restrict, quem ja treinou nao conseguiria mais
  // editar o proprio plano. O historico sobrevive sem saber de que dia veio —
  // os SetLog penduram na sessao, nao no dia, entao nada de dado se perde.
  planDay   PlanDay? @relation(fields: [planDayId], references: [id], onDelete: SetNull)

  date        DateTime  @default(now())
  // null = sessao em aberto. E o que o POST /sessions procura pra devolver a
  // sessao existente em vez de criar uma duplicada.
  finishedAt  DateTime?
  durationSec Int?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  setLogs     SetLog[]

  // "a sessao aberta do usuario X" — a consulta do POST /sessions.
  @@index([userId, finishedAt])
  // "historico do usuario X, mais recente primeiro" — a consulta do GET /sessions.
  @@index([userId, date])
  @@index([planDayId])
}

model SetLog {
  id         String         @id @default(cuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  // Restrict (padrao), igual PlanExercise: nao deixa sumir exercicio com historico.
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
  setNumber  Int
  weightKg   Float?
  reps       Int?
  rpe        Float?
  completed  Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // Torna o registro de serie idempotente: reenviar a mesma serie (retry de
  // rede, ou corrigir a carga digitada errada) atualiza em vez de duplicar.
  // Sem isto, um retry no metro viraria volume fantasma nos graficos da Fase 4.
  @@unique([sessionId, exerciseId, setNumber])
  @@index([sessionId])
  // Busca da "ultima carga" (GET /sessions/last-loads) filtra por exercicio.
  @@index([exerciseId])
}

/**
 * Peso corporal e composicao ao longo do tempo — a serie que alimenta o
 * terceiro grafico de /progress.
 *
 * Nao confundir com Profile.weightKg, que e o peso declarado uma vez no
 * cadastro e serve pra IA dimensionar o plano. Este aqui e historico: varias
 * medidas por usuario, cada uma com data. Sao coisas diferentes de proposito.
 */
model BodyMetric {
  id       String   @id @default(cuid())
  userId   String
  // Cascade, igual WorkoutSession: apagar a conta leva junto os dados pessoais.
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     DateTime @default(now())
  // Tudo nullable: pesar sem medir bodyFat e o caso comum, e o contrario
  // (so uma anotacao) tambem e valido. Vale pra composicao inteira — quem
  // sobe na balanca todo dia nao passa a fita metrica todo dia.
  weightKg Float?
  bodyFat  Float?
  notes    String?

  // Composicao corporal, registrada em /profile (secao avancada). Mora aqui e
  // nao no Profile de proposito: sao medidas que mudam ao longo do tempo, e o
  // Profile guarda o que voce declara uma vez. Ter os dois seria ter dois
  // numeros que discordam — o problema que Profile.weightKg ja tem hoje.
  leanMassKg Float?
  waistCm    Float?
  armCm      Float?
  chestCm    Float?
  thighCm    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // "meu peso ao longo do tempo" — a unica leitura que existe.
  @@index([userId, date])
}

/**
 * XP acumulado e nivel do usuario.
 *
 * Estado persistido, somado ao fechar cada sessao — nao derivado do historico.
 * A escolha e deliberada: o multiplicador de XP usa a sequencia do MOMENTO em
 * que voce fechou o treino, e reconstruir a sequencia de cada sessao passada
 * seria caro e fragil. Acumular resolve isso de graca.
 *
 * De proposito NAO guarda sequencia aqui (o plano original previa
 * currentStreak/longestStreak/streakFreezes). A sequencia ja existe, derivada
 * do historico em progress/streak.ts, com a regra de dias agendados cumpridos
 * com reposicao. Duplicar viraria duas verdades sobre a mesma chama, divergindo
 * em silencio.
 */
model GameProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  // Cascade, igual Profile: apagar a conta leva junto o progresso.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp        Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Catalogo fixo de conquistas, populado pelo seed (upsert por `code`).
 *
 * Mora no banco e nao so em codigo porque UserAchievement referencia por FK —
 * mas a fonte da verdade do catalogo continua sendo game/catalog.ts, que o seed
 * le. Editar o catalogo la e re-semear e o fluxo.
 */
model Achievement {
  id          String            @id @default(cuid())
  // Chave estavel usada pelo codigo ("FIRST_PR"); o id muda entre ambientes.
  code        String            @unique
  name        String
  description String
  icon        String
  xpReward    Int               @default(0)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  // Restrict (padrao): nao deixa sumir do catalogo uma conquista ja desbloqueada.
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  // O banco e a autoridade contra corrida: dois finish simultaneos que avaliem
  // a mesma conquista nao conseguem grava-la duas vezes.
  @@unique([userId, achievementId])
  // "as conquistas do usuario X" — a consulta do GET /game/achievements.
  @@index([userId])
}
