{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  // Inclui test/prisma/configs de proposito: sem eles o `typecheck` passava
  // por cima do seed e dos testes, que nunca eram verificados. O build usa
  // tsconfig.build.json, que exclui tudo isso do dist.
  "include": [
    "src",
    "test",
    "prisma",
    "vitest.config.ts",
    "vitest.e2e.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
