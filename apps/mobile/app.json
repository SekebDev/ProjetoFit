{
  "expo": {
    "name": "Hipertrof.AI",
    "slug": "hipertrof-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hipertrof",
    "userInterfaceStyle": "dark",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.hipertrof.ai",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0e1014",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eacbc8b0-8be5-4c38-9d35-1564ed4703da"
      }
    },
    "owner": "sekeb"
  }
}
